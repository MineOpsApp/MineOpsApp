EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:8080/api

# Mapbox — get tokens from https://account.mapbox.com/
# Public token (pk.) — put in .env for dev, add as EAS env var for cloud builds
EXPO_PUBLIC_MAPBOX_TOKEN=pk.YOUR_PUBLIC_TOKEN_HERE
# Secret download token (sk.) — NEVER commit. Set via: eas secret:create --name MAPBOX_SECRET_TOKEN --value sk.xxx
# Also add to your local shell/env if running expo prebuild locally.
MAPBOX_SECRET_TOKEN=sk.YOUR_SECRET_TOKEN_HERE
